package flatgeobuf:format@0.1.0;

/// FlatGeobuf WebAssembly Component
///
/// Provides FlatGeobuf format support - a performant binary
/// format for geographic data with spatial indexing.
world flatgeobuf-component {
    /// Import geozero for format conversions
    import geozero:convert/geozero-api@0.1.0;

    /// Export the FlatGeobuf API
    export flatgeobuf-api;
}
